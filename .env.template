# ChromaDB + Cloudflared — environment template
# Copy this file to .env and fill in real values. Never commit .env.
#
# Usage:
#   cp .env.template .env
#   # then edit .env with your actual values

# ---------------------------------------------------------------------------
# ChromaDB
# ---------------------------------------------------------------------------

# Absolute path on the host where ChromaDB persists its vector data.
# The directory is mounted as /data inside the container.
# Pre-create it before first run:  sudo mkdir -p /srv/chroma-data
CHROMA_DATA_DIR=/absolute/path/to/chroma-data

# ---------------------------------------------------------------------------
# Cloudflare Tunnel
# ---------------------------------------------------------------------------

# Tunnel token generated in Cloudflare Zero Trust > Networks > Tunnels.
# Paste the token string exactly as shown by the dashboard — do not wrap in quotes.
# In Zero Trust, configure the tunnel's public hostname to forward to:
#   http://chromadb:8000
TUNNEL_TOKEN=your_tunnel_token_here
